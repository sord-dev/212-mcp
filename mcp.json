{
  "name": "Trading212 MCP Server",
  "description": "Fetches Trading212 portfolio positions and account balance data",
  "version": "1.0.0",
  "server": {
    "url": "http://localhost:8000",
    "type": "http"
  },
  "tools": [
    {
      "name": "get_balance",
      "description": "Get Trading212 account balance including total value, free cash, invested amount, and profit/loss",
      "endpoint": "/tools/get_balance",
      "method": "POST",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number",
            "description": "Total account value in GBP"
          },
          "free": {
            "type": "number",
            "description": "Available cash in GBP"
          },
          "invested": {
            "type": "number", 
            "description": "Total invested amount in GBP"
          },
          "ppl": {
            "type": "number",
            "description": "Profit/Loss in GBP"
          },
          "currency": {
            "type": "string",
            "description": "Account currency (GBP)"
          }
        },
        "required": ["total", "free", "invested", "ppl", "currency"]
      }
    },
    {
      "name": "get_positions", 
      "description": "Get current Trading212 portfolio positions with detailed information for each holding",
      "endpoint": "/tools/get_positions",
      "method": "POST",
      "inputSchema": {
        "type": "object",
        "properties": {},
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "positions": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "instrument": {
                  "type": "object",
                  "properties": {
                    "ticker": {
                      "type": "string",
                      "description": "Stock/ETF ticker symbol (e.g. AAPL_US_EQ)"
                    },
                    "name": {
                      "type": "string",
                      "description": "Full name of the instrument"
                    },
                    "currency": {
                      "type": "string",
                      "description": "Instrument currency"
                    },
                    "isin": {
                      "type": "string",
                      "description": "International Securities Identification Number"
                    }
                  }
                },
                "quantity": {
                  "type": "number",
                  "description": "Total number of shares/units held"
                },
                "quantityAvailableForTrading": {
                  "type": "number",
                  "description": "Number of shares available for trading"
                },
                "quantityInPies": {
                  "type": "number",
                  "description": "Number of shares allocated to pies"
                },
                "averagePrice": {
                  "type": "number",
                  "description": "Average purchase price per share"
                },
                "currentPrice": {
                  "type": "number",
                  "description": "Current market price per share"
                },
                "ppl": {
                  "type": "number",
                  "description": "Unrealized profit/loss for this position"
                },
                "currentValue": {
                  "type": "number",
                  "description": "Current market value of the position"
                },
                "totalCost": {
                  "type": "number",
                  "description": "Total cost of the position"
                },
                "fxImpact": {
                  "type": "number",
                  "description": "Foreign exchange impact on the position"
                },
                "createdAt": {
                  "type": "string",
                  "description": "ISO timestamp of when position was created"
                }
              }
            }
          },
          "count": {
            "type": "integer",
            "description": "Total number of positions"
          }
        },
        "required": ["positions", "count"]
      }
    }
  ]
}